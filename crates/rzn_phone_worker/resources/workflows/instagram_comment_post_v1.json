{
  "schema_version": "rzn.mobile.workflow.v1",
  "name": "instagram.comment_post",
  "version": "1.0.0",
  "description": "Open a visible Instagram post, draft a comment, and optionally submit it with commit gating.",
  "inputs": {
    "comment_text": { "type": "string", "required": true },
    "execute_comment": { "type": "boolean", "default": false },
    "post_position": { "type": "integer", "default": 1, "min": 1, "max": 4 },
    "comment_field_predicate": { "type": "string", "default": "type == 'XCUIElementTypeTextView' AND (name == 'text-view' OR label CONTAINS[c] 'Add a comment' OR value CONTAINS[c] 'Add a comment')" },
    "send_button_predicate": { "type": "string", "default": "type == 'XCUIElementTypeButton' AND name == 'send-button'" },
    "maxNodes": { "type": "integer", "default": 240, "min": 80, "max": 420 }
  },
  "notes": [
    "Dry-run by default.",
    "The workflow enters the comments sheet via the visible feed comment button, drafts text, and only posts when execute_comment=true and commit=true."
  ],
  "steps": [
    { "tool": "ios.appium.ensure", "arguments": {} },
    {
      "tool": "ios.session.create",
      "arguments": {
        "udid": "{{udid}}",
        "kind": "native_app",
        "bundleId": "com.burbn.instagram",
        "replaceExisting": true,
        "noReset": true,
        "showXcodeLog": "{{showXcodeLog}}",
        "allowProvisioningUpdates": "{{allowProvisioningUpdates}}",
        "allowProvisioningDeviceRegistration": "{{allowProvisioningDeviceRegistration}}",
        "sessionCreateTimeoutMs": "{{sessionCreateTimeoutMs}}",
        "wdaLocalPort": "{{wdaLocalPort}}",
        "wdaLaunchTimeoutMs": "{{wdaLaunchTimeoutMs}}",
        "wdaConnectionTimeoutMs": "{{wdaConnectionTimeoutMs}}",
        "signing": {
          "xcodeOrgId": "{{xcodeOrgId}}",
          "xcodeSigningId": "{{xcodeSigningId}}",
          "updatedWDABundleId": "{{updatedWDABundleId}}"
        }
      }
    },
    {
      "tool": "ios.app.activate",
      "arguments": {
        "bundleId": "com.burbn.instagram",
        "terminateFirst": true
      }
    },
    {
      "tool": "ios.action.wait",
      "arguments": {
        "target": {
          "using": "-ios predicate string",
          "value": "name == 'mainfeed-tab' OR name == 'main-feed-screen' OR name == 'main-feed' OR name == 'create'"
        },
        "timeoutMs": 30000
      },
      "retries": 1
    },
    { "tool": "util.sleep", "arguments": { "minMs": 2200, "maxMs": 2200 } },
    {
      "tool": "ios.action.tap",
      "arguments": {
        "target": { "using": "accessibility id", "value": "mainfeed-tab" }
      }
    },
    { "tool": "util.sleep", "arguments": { "minMs": 900, "maxMs": 900 } },
    {
      "tool": "ios.action.scroll",
      "arguments": { "direction": "down", "distance": 0.22 }
    },
    { "tool": "util.sleep", "arguments": { "minMs": 850, "maxMs": 850 } },
    { "tool": "ios.ui.source", "arguments": {}, "saveAs": "feedUiSource" },
    {
      "tool": "ios.ui.extract_rows",
      "saveAs": "feedRows",
      "arguments": {
        "source": "{{steps.feedUiSource.source}}",
        "row": {
          "type": "XCUIElementTypeCell",
          "name": "media-cell",
          "ancestorName": "main-feed"
        },
        "primary": {
          "type": "XCUIElementTypeOther",
          "attr": "value",
          "pick": "longest"
        },
        "fields": [
          {
            "name": "username",
            "query": {
              "type": "XCUIElementTypeButton",
              "name": "feed-item-header-user-button",
              "max": 1
            },
            "attr": "label",
            "pick": "first"
          }
        ],
        "limit": 4,
        "order": "y"
      }
    },
    {
      "tool": "util.list.nth",
      "saveAs": "selectedPost",
      "arguments": { "list": "{{steps.feedRows.rows}}", "index": "{{post_position}}" }
    },
    {
      "tool": "util.rank_by_name",
      "saveAs": "selectedPostRank",
      "arguments": {
        "items": "{{steps.feedRows.rows}}",
        "field": "rawLabel",
        "target": "{{steps.selectedPost.value.rawLabel}}"
      }
    },
    {
      "tool": "ios.action.tap",
      "arguments": {
        "target": {
          "using": "-ios predicate string",
          "value": "type == 'XCUIElementTypeButton' AND name == 'comment-button'",
          "index": "{{steps.selectedPostRank.index}}"
        }
      }
    },
    { "tool": "util.sleep", "arguments": { "minMs": 1800, "maxMs": 1800 } },
    {
      "tool": "ios.action.wait",
      "arguments": {
        "target": { "using": "-ios predicate string", "value": "{{comment_field_predicate}}" },
        "timeoutMs": 15000
      },
      "retries": 1
    },
    {
      "tool": "ios.action.type",
      "arguments": {
        "target": { "using": "-ios predicate string", "value": "{{comment_field_predicate}}" },
        "text": "{{comment_text}}",
        "clearFirst": true
      }
    },
    { "tool": "ios.ui.screenshot", "arguments": {}, "saveAs": "draftCommentScreenshot" },
    { "tool": "ios.ui.source", "arguments": {}, "saveAs": "draftCommentUiSource" },
    {
      "tool": "ios.ui.observe_compact",
      "arguments": { "nodeFilter": "all", "maxNodes": "{{maxNodes}}" },
      "saveAs": "draftCommentCompactSnapshot"
    },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "sendButtonVisible",
      "arguments": {
        "query": { "type": "XCUIElementTypeButton", "name": "send-button", "max": 2 },
        "limit": 2,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "util.list.length",
      "saveAs": "sendButtonVisibleCount",
      "arguments": { "list": "{{steps.sendButtonVisible.texts}}" }
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "steps.sendButtonVisibleCount.count", "truthy": true },
      "requiresCommit": true,
      "arguments": { "target": { "using": "-ios predicate string", "value": "{{send_button_predicate}}" } }
    },
    {
      "tool": "ios.ui.screenshot",
      "when": { "var": "steps.sendButtonVisibleCount.count", "truthy": true },
      "arguments": {},
      "saveAs": "afterCommentScreenshot"
    }
  ],
  "output": {
    "requestedComment": "{{execute_comment}}",
    "selectedPost": "{{steps.selectedPost.value}}",
    "selectedPostIndex": "{{steps.selectedPostRank.index}}",
    "sendButtonVisibleCount": "{{steps.sendButtonVisibleCount.count}}",
    "screenshot": "{{steps.draftCommentScreenshot}}",
    "uiSource": "{{steps.draftCommentUiSource}}",
    "compactSnapshot": "{{steps.draftCommentCompactSnapshot}}",
    "afterCommentScreenshot": "{{steps.afterCommentScreenshot}}"
  }
}
