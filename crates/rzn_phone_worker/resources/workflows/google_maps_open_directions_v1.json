{
  "schema_version": "rzn.mobile.workflow.v1",
  "name": "google_maps.open_directions",
  "version": "1.0.0",
  "description": "Open a Google Maps place sheet, tap Directions, and capture the post-tap route context.",
  "inputs": {
    "query": { "type": "string", "required": true },
    "maxNodes": { "type": "integer", "default": 220, "min": 80, "max": 420 }
  },
  "notes": [
    "Read-only workflow.",
    "Best-effort: current Google Maps builds may keep the place sheet visible after tapping Directions while updating route context.",
    "Validated on the connected device with an airport destination query."
  ],
  "steps": [
    { "tool": "ios.appium.ensure", "arguments": {} },
    {
      "tool": "ios.session.create",
      "arguments": {
        "udid": "{{udid}}",
        "kind": "native_app",
        "bundleId": "com.google.Maps",
        "replaceExisting": true,
        "noReset": true,
        "showXcodeLog": "{{showXcodeLog}}",
        "allowProvisioningUpdates": "{{allowProvisioningUpdates}}",
        "allowProvisioningDeviceRegistration": "{{allowProvisioningDeviceRegistration}}",
        "sessionCreateTimeoutMs": "{{sessionCreateTimeoutMs}}",
        "wdaLocalPort": "{{wdaLocalPort}}",
        "wdaLaunchTimeoutMs": "{{wdaLaunchTimeoutMs}}",
        "wdaConnectionTimeoutMs": "{{wdaConnectionTimeoutMs}}",
        "signing": {
          "xcodeOrgId": "{{xcodeOrgId}}",
          "xcodeSigningId": "{{xcodeSigningId}}",
          "updatedWDABundleId": "{{updatedWDABundleId}}"
        }
      }
    },
    {
      "tool": "ios.app.activate",
      "arguments": {
        "bundleId": "com.google.Maps",
        "terminateFirst": true
      }
    },
    {
      "tool": "ios.action.wait",
      "arguments": {
        "target": { "using": "accessibility id", "value": "SearchHeaderSearchTxtView" },
        "timeoutMs": 30000
      },
      "retries": 1
    },
    { "tool": "util.sleep", "arguments": { "minMs": 400, "maxMs": 900 } },
    {
      "tool": "ios.action.tap",
      "arguments": {
        "target": { "using": "accessibility id", "value": "SearchHeaderSearchTxtView" }
      }
    },
    {
      "tool": "ios.action.type",
      "arguments": {
        "target": { "using": "accessibility id", "value": "SearchHeaderSearchTxtView" },
        "text": "{{query}}",
        "clearFirst": true,
        "pressEnter": true
      }
    },
    {
      "tool": "ios.action.wait",
      "arguments": {
        "target": { "using": "xpath", "value": "//XCUIElementTypeButton[@name='Directions' or @label='Directions']" },
        "timeoutMs": 30000
      },
      "retries": 1
    },
    { "tool": "util.sleep", "arguments": { "minMs": 1200, "maxMs": 2200 } },
    {
      "tool": "ios.action.tap",
      "arguments": {
        "target": { "using": "xpath", "value": "//XCUIElementTypeButton[@name='Directions' or @label='Directions']" }
      }
    },
    { "tool": "util.sleep", "arguments": { "minMs": 1200, "maxMs": 2200 } },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "routeOptions",
      "arguments": {
        "query": {
          "type": "XCUIElementTypeButton",
          "nameContains": "away from your current location",
          "max": 8
        },
        "limit": 6,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "modeSummary",
      "arguments": {
        "query": {
          "type": "XCUIElementTypeButton",
          "nameContains": "Driving",
          "max": 2
        },
        "limit": 1,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "util.list.first",
      "saveAs": "summaryLine",
      "arguments": { "list": "{{steps.modeSummary.texts}}", "field": "text" }
    },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "staticTexts",
      "arguments": {
        "query": { "type": "XCUIElementTypeStaticText", "max": 20 },
        "limit": 12,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "buttonTexts",
      "arguments": {
        "query": { "type": "XCUIElementTypeButton", "max": 20 },
        "limit": 12,
        "unique": true,
        "order": "y"
      }
    },
    { "tool": "ios.ui.screenshot", "arguments": {}, "saveAs": "screenshot" },
    { "tool": "ios.ui.source", "arguments": {}, "saveAs": "uiSource" },
    {
      "tool": "ios.ui.observe_compact",
      "arguments": { "nodeFilter": "all", "maxNodes": "{{maxNodes}}" },
      "saveAs": "compactSnapshot"
    }
  ],
  "output": {
    "query": "{{query}}",
    "title": "{{query}}",
    "summaryLine": "{{steps.summaryLine.value}}",
    "detailsLine": "{{steps.staticTexts.texts}}",
    "routeOptions": "{{steps.routeOptions.texts}}",
    "buttonTexts": "{{steps.buttonTexts.texts}}",
    "screenshot": "{{steps.screenshot}}",
    "uiSource": "{{steps.uiSource}}",
    "compactSnapshot": "{{steps.compactSnapshot}}"
  }
}
