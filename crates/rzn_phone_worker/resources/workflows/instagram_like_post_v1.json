{
  "schema_version": "rzn.mobile.workflow.v1",
  "name": "instagram.like_post",
  "version": "1.0.0",
  "description": "Optionally like a visible Instagram feed post with dual execute and commit gating.",
  "inputs": {
    "execute_like": { "type": "boolean", "default": false },
    "post_position": { "type": "integer", "default": 1, "min": 1, "max": 4 },
    "maxNodes": { "type": "integer", "default": 240, "min": 80, "max": 420 }
  },
  "notes": [
    "Dry-run by default.",
    "The workflow force-relaunches Instagram before reading the feed so open comments, composer, or media-viewer state cannot hijack the like target.",
    "Actual mutation requires both args.execute_like=true and commit=true."
  ],
  "steps": [
    { "tool": "ios.appium.ensure", "arguments": {} },
    {
      "tool": "ios.session.create",
      "arguments": {
        "udid": "{{udid}}",
        "kind": "native_app",
        "bundleId": "com.burbn.instagram",
        "replaceExisting": true,
        "noReset": true,
        "showXcodeLog": "{{showXcodeLog}}",
        "allowProvisioningUpdates": "{{allowProvisioningUpdates}}",
        "allowProvisioningDeviceRegistration": "{{allowProvisioningDeviceRegistration}}",
        "sessionCreateTimeoutMs": "{{sessionCreateTimeoutMs}}",
        "wdaLocalPort": "{{wdaLocalPort}}",
        "wdaLaunchTimeoutMs": "{{wdaLaunchTimeoutMs}}",
        "wdaConnectionTimeoutMs": "{{wdaConnectionTimeoutMs}}",
        "signing": {
          "xcodeOrgId": "{{xcodeOrgId}}",
          "xcodeSigningId": "{{xcodeSigningId}}",
          "updatedWDABundleId": "{{updatedWDABundleId}}"
        }
      }
    },
    {
      "tool": "ios.app.activate",
      "arguments": {
        "bundleId": "com.burbn.instagram",
        "terminateFirst": true
      }
    },
    {
      "tool": "ios.action.wait",
      "arguments": {
        "target": {
          "using": "-ios predicate string",
          "value": "name == 'mainfeed-tab' OR name == 'main-feed-screen' OR name == 'main-feed' OR name == 'create'"
        },
        "timeoutMs": 30000
      },
      "retries": 1
    },
    { "tool": "util.sleep", "arguments": { "minMs": 2200, "maxMs": 2200 } },
    {
      "tool": "ios.action.tap",
      "arguments": {
        "target": { "using": "accessibility id", "value": "mainfeed-tab" }
      }
    },
    { "tool": "util.sleep", "arguments": { "minMs": 900, "maxMs": 900 } },
    {
      "tool": "ios.action.scroll",
      "arguments": { "direction": "down", "distance": 0.22 }
    },
    { "tool": "util.sleep", "arguments": { "minMs": 850, "maxMs": 850 } },
    { "tool": "ios.ui.source", "arguments": {}, "saveAs": "feedUiSource" },
    {
      "tool": "ios.ui.extract_rows",
      "saveAs": "feedRows",
      "arguments": {
        "source": "{{steps.feedUiSource.source}}",
        "row": {
          "type": "XCUIElementTypeCell",
          "name": "media-cell",
          "ancestorName": "main-feed"
        },
        "primary": {
          "type": "XCUIElementTypeOther",
          "attr": "value",
          "pick": "longest"
        },
        "fields": [
          {
            "name": "username",
            "query": {
              "type": "XCUIElementTypeButton",
              "name": "feed-item-header-user-button",
              "max": 1
            },
            "attr": "label",
            "pick": "first"
          }
        ],
        "limit": 4,
        "order": "y"
      }
    },
    {
      "tool": "util.list.nth",
      "saveAs": "selectedPost",
      "arguments": { "list": "{{steps.feedRows.rows}}", "index": "{{post_position}}" }
    },
    {
      "tool": "util.rank_by_name",
      "saveAs": "selectedPostRank",
      "arguments": {
        "items": "{{steps.feedRows.rows}}",
        "field": "rawLabel",
        "target": "{{steps.selectedPost.value.rawLabel}}"
      }
    },
    { "tool": "ios.ui.screenshot", "arguments": {}, "saveAs": "beforeLikeScreenshot" },
    {
      "tool": "ios.ui.observe_compact",
      "arguments": { "nodeFilter": "all", "maxNodes": "{{maxNodes}}" },
      "saveAs": "beforeLikeCompactSnapshot"
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "execute_like", "truthy": true },
      "requiresCommit": true,
      "arguments": {
        "target": {
          "using": "-ios predicate string",
          "value": "type == 'XCUIElementTypeButton' AND name == 'like-button'",
          "index": "{{steps.selectedPostRank.index}}"
        }
      }
    },
    {
      "tool": "ios.ui.screenshot",
      "when": { "var": "execute_like", "truthy": true },
      "arguments": {},
      "saveAs": "afterLikeScreenshot"
    }
  ],
  "output": {
    "requestedLike": "{{execute_like}}",
    "selectedPost": "{{steps.selectedPost.value}}",
    "selectedPostIndex": "{{steps.selectedPostRank.index}}",
    "screenshot": "{{steps.beforeLikeScreenshot}}",
    "uiSource": "{{steps.feedUiSource}}",
    "compactSnapshot": "{{steps.beforeLikeCompactSnapshot}}",
    "afterLikeScreenshot": "{{steps.afterLikeScreenshot}}"
  }
}
