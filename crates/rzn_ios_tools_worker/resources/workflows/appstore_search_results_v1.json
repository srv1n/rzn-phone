{
  "schema_version": "rzn.mobile.workflow.v1",
  "name": "appstore.search_results",
  "version": "1.1.0",
  "description": "Submit an App Store search query, capture ordered result rows, and compute optional observed rank (read-only).",
  "inputs": {
    "query": { "type": "string", "required": true },
    "target_app_name": { "type": "string" },
    "limit": { "type": "integer", "default": 10, "min": 1, "max": 50 },
    "maxScrolls": { "type": "integer", "default": 5, "min": 0, "max": 12 },
    "typing_mode": { "type": "string", "default": "full" },
    "country": { "type": "string" },
    "locale": { "type": "string" }
  },
  "notes": [
    "Read-only workflow: opens App Store Search and scrapes visible rows.",
    "Includes compact snapshot + screenshot of the top fold for debugging.",
    "Uses bounded scrolling for top-N extraction."
  ],
  "steps": [
    { "tool": "ios.appium.ensure", "arguments": {} },
    {
      "tool": "ios.session.create",
      "arguments": {
        "udid": "{{udid}}",
        "kind": "native_app",
        "bundleId": "com.apple.AppStore",
        "replaceExisting": true,
        "noReset": true,
        "showXcodeLog": "{{showXcodeLog}}",
        "allowProvisioningUpdates": "{{allowProvisioningUpdates}}",
        "allowProvisioningDeviceRegistration": "{{allowProvisioningDeviceRegistration}}",
        "sessionCreateTimeoutMs": "{{sessionCreateTimeoutMs}}",
        "wdaLaunchTimeoutMs": "{{wdaLaunchTimeoutMs}}",
        "wdaConnectionTimeoutMs": "{{wdaConnectionTimeoutMs}}",
        "signing": {
          "xcodeOrgId": "{{xcodeOrgId}}",
          "xcodeSigningId": "{{xcodeSigningId}}",
          "updatedWDABundleId": "{{updatedWDABundleId}}"
        }
      }
    },
    {
      "tool": "ios.action.wait",
      "arguments": {
        "target": { "using": "accessibility id", "value": "AppStore.tabBar.search" },
        "timeoutMs": 30000
      },
      "retries": 1
    },
    {
      "tool": "ios.action.tap",
      "arguments": {
        "target": { "using": "accessibility id", "value": "AppStore.tabBar.search" }
      }
    },
    {
      "tool": "ios.action.tap",
      "arguments": {
        "target": { "using": "accessibility id", "value": "AppStore.searchField" }
      }
    },
    {
      "tool": "ios.action.type",
      "arguments": {
        "target": { "using": "accessibility id", "value": "AppStore.searchField" },
        "text": "{{query}}\n",
        "clearFirst": true
      }
    },
    {
      "tool": "ios.action.wait",
      "arguments": {
        "target": { "using": "accessibility id", "value": "AppStore.searchResults" },
        "timeoutMs": 30000
      },
      "retries": 1
    },
    {
      "tool": "ios.ui.observe_compact",
      "arguments": { "nodeFilter": "all", "maxNodes": 220 },
      "saveAs": "compactSnapshot"
    },
    { "tool": "ios.ui.screenshot", "arguments": {}, "saveAs": "screenshot" },
    { "tool": "ios.ui.source", "arguments": {}, "saveAs": "uiSource" },
    {
      "tool": "ios.ui.extract_rows",
      "saveAs": "results",
      "arguments": {
        "row": {
          "type": "XCUIElementTypeCell",
          "namePrefix": "AppStore.shelfItem.searchResult",
          "ancestorName": "AppStore.searchResults"
        },
        "primary": {
          "type": "XCUIElementTypeButton",
          "attr": "label",
          "pick": "longest"
        },
        "split": {
          "delimiter": ",",
          "fields": ["name", "subtitle", "developer"],
          "skipMetricLike": true
        },
        "limit": "{{limit}}",
        "maxScrolls": "{{maxScrolls}}",
        "scroll": { "direction": "down", "distance": 0.6, "settleMs": 350 }
      }
    },
    {
      "tool": "util.rank_by_name",
      "saveAs": "rank",
      "arguments": {
        "items": "{{steps.results.rows}}",
        "field": "name",
        "target": "{{target_app_name}}"
      }
    }
  ],
  "output": {
    "query": "{{query}}",
    "results": "{{steps.results.rows}}",
    "resultCount": "{{steps.results.rowCount}}",
    "observed_rank": "{{steps.rank.rank}}",
    "screenshot": "{{steps.screenshot}}",
    "uiSource": "{{steps.uiSource}}",
    "compactSnapshot": "{{steps.compactSnapshot}}"
  }
}
