{
  "schema_version": "rzn.mobile.workflow.v1",
  "name": "appstore.app_details",
  "version": "1.0.2",
  "description": "Open an App Store search result and extract top-level app metadata + badges (read-only).",
  "inputs": {
    "query": { "type": "string", "required": true },
    "result_index": { "type": "integer", "default": 0, "min": 0, "max": 50 },
    "submit_mode": { "type": "string", "default": "keyboard" },
    "screenshot_limit": { "type": "integer", "default": 10, "min": 1, "max": 25 },
    "country": { "type": "string" },
    "locale": { "type": "string" }
  },
  "notes": [
    "Read-only workflow: no purchase/download actions.",
    "result_index is 0-based (0 = first search result)."
  ],
  "steps": [
    { "tool": "ios.appium.ensure", "arguments": {} },
    {
      "tool": "ios.session.create",
      "arguments": {
        "udid": "{{udid}}",
        "kind": "native_app",
        "bundleId": "com.apple.AppStore",
        "replaceExisting": true,
        "noReset": true,
        "showXcodeLog": "{{showXcodeLog}}",
        "allowProvisioningUpdates": "{{allowProvisioningUpdates}}",
        "allowProvisioningDeviceRegistration": "{{allowProvisioningDeviceRegistration}}",
        "sessionCreateTimeoutMs": "{{sessionCreateTimeoutMs}}",
        "wdaLaunchTimeoutMs": "{{wdaLaunchTimeoutMs}}",
        "wdaConnectionTimeoutMs": "{{wdaConnectionTimeoutMs}}",
        "signing": {
          "xcodeOrgId": "{{xcodeOrgId}}",
          "xcodeSigningId": "{{xcodeSigningId}}",
          "updatedWDABundleId": "{{updatedWDABundleId}}"
        }
      }
    },
    {
      "tool": "ios.action.wait",
      "arguments": {
        "target": { "using": "accessibility id", "value": "AppStore.tabBar.search" },
        "timeoutMs": 30000
      },
      "retries": 1
    },
    {
      "tool": "ios.action.tap",
      "arguments": {
        "target": { "using": "accessibility id", "value": "AppStore.tabBar.search" }
      }
    },
    {
      "tool": "ios.action.tap",
      "arguments": {
        "target": { "using": "accessibility id", "value": "AppStore.searchField" }
      }
    },
    {
      "tool": "ios.action.type",
      "when": { "var": "submit_mode", "equals": "suggestion" },
      "arguments": {
        "target": { "using": "accessibility id", "value": "AppStore.searchField" },
        "text": "{{query}}",
        "clearFirst": true
      }
    },
    {
      "tool": "ios.action.type",
      "when": { "var": "submit_mode", "equals": "keyboard" },
      "arguments": {
        "target": { "using": "accessibility id", "value": "AppStore.searchField" },
        "text": "{{query}}",
        "clearFirst": true,
        "pressEnter": true
      }
    },
    {
      "tool": "ios.ui.extract_text",
      "when": { "var": "submit_mode", "equals": "keyboard" },
      "saveAs": "keyboardHints",
      "arguments": {
        "query": { "type": "XCUIElementTypeCell", "ancestorName": "AppStore.searchHints", "max": 2 },
        "limit": 2,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "util.list.first",
      "when": { "var": "submit_mode", "equals": "keyboard" },
      "saveAs": "keyboardHintFirst",
      "arguments": { "list": "{{steps.keyboardHints.texts}}" }
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "steps.keyboardHintFirst.found", "truthy": true },
      "arguments": { "target": { "using": "xpath", "value": "//XCUIElementTypeCollectionView[@name='AppStore.searchHints']//XCUIElementTypeCell[1]" } }
    },
    {
      "tool": "ios.action.wait",
      "when": { "var": "submit_mode", "equals": "suggestion" },
      "arguments": {
        "target": { "using": "xpath", "value": "//XCUIElementTypeCollectionView[@name='AppStore.searchHints']//XCUIElementTypeCell[1]" },
        "timeoutMs": 10000
      },
      "retries": 1
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "submit_mode", "equals": "suggestion" },
      "arguments": { "target": { "using": "xpath", "value": "//XCUIElementTypeCollectionView[@name='AppStore.searchHints']//XCUIElementTypeCell[1]" } }
    },
    {
      "tool": "ios.action.wait",
      "arguments": {
        "target": { "using": "xpath", "value": "//XCUIElementTypeCell[starts-with(@name, 'AppStore.shelfItem.searchResult')]" },
        "timeoutMs": 30000
      },
      "retries": 1
    },
    {
      "tool": "ios.action.tap",
      "arguments": {
        "target": { "using": "xpath", "value": "//XCUIElementTypeCell[starts-with(@name, 'AppStore.shelfItem.searchResult')]", "index": "{{result_index}}" }
      }
    },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "dismissButtons",
      "arguments": {
        "query": { "type": "XCUIElementTypeButton", "name": "AppStore.dismissButton", "max": 2 },
        "limit": 2,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "util.list.first",
      "saveAs": "dismissFirst",
      "arguments": { "list": "{{steps.dismissButtons.texts}}" }
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "steps.dismissFirst.found", "truthy": true },
      "arguments": { "target": { "using": "accessibility id", "value": "AppStore.dismissButton" } }
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "steps.dismissFirst.found", "truthy": true },
      "arguments": {
        "target": { "using": "xpath", "value": "//XCUIElementTypeCell[starts-with(@name, 'AppStore.shelfItem.searchResult')]", "index": "{{result_index}}" }
      }
    },
    {
      "tool": "ios.action.wait",
      "arguments": {
        "target": { "using": "xpath", "value": "//XCUIElementTypeCell[starts-with(@name, 'AppStore.shelfItem.productTopLockup')]" },
        "timeoutMs": 30000
      },
      "retries": 1
    },
    {
      "tool": "ios.ui.extract_rows",
      "saveAs": "topLockup",
      "arguments": {
        "row": {
          "type": "XCUIElementTypeCell",
          "nameContains": "productTopLockup"
        },
        "primary": {
          "type": "XCUIElementTypeCell",
          "attr": "name",
          "pick": "first"
        },
        "fields": [
          {
            "name": "title",
            "query": { "type": "XCUIElementTypeStaticText", "name": "AppStore.shelfItemSubComponent.title", "max": 3 },
            "attr": "label",
            "pick": "first"
          },
          {
            "name": "tagline",
            "query": { "type": "XCUIElementTypeStaticText", "name": "AppStore.shelfItemSubComponent.tagline", "max": 3 },
            "attr": "label",
            "pick": "first"
          },
          {
            "name": "subtitle",
            "query": { "type": "XCUIElementTypeStaticText", "name": "AppStore.shelfItemSubComponent.subtitle", "max": 3 },
            "attr": "label",
            "pick": "first"
          },
          {
            "name": "developer",
            "query": { "type": "XCUIElementTypeButton", "name": "AppStore.shelfItemSubComponent.developer", "max": 2 },
            "attr": "label",
            "pick": "first"
          },
          {
            "name": "offer",
            "query": { "type": "XCUIElementTypeButton", "nameContains": "AppStore.offerButton", "max": 2 },
            "attr": "label",
            "pick": "first"
          },
          {
            "name": "offerSubtitle",
            "query": { "type": "XCUIElementTypeStaticText", "name": "AppStore.shelfItemSubComponent.offerButtonSubtitle", "max": 2 },
            "attr": "label",
            "pick": "first"
          }
        ],
        "limit": 1
      }
    },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "badges",
      "arguments": {
        "query": { "type": "XCUIElementTypeButton", "namePrefix": "AppStore.productPage.badge.", "max": 20 },
        "limit": 10,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "ios.ui.extract_rows",
      "saveAs": "screenshots",
      "arguments": {
        "row": {
          "type": "XCUIElementTypeCell",
          "namePrefix": "AppStore.shelfItem.productMediaItem"
        },
        "primary": {
          "type": "XCUIElementTypeCell",
          "attr": "name",
          "pick": "first"
        },
        "limit": "{{screenshot_limit}}",
        "order": "x"
      }
    },
    { "tool": "ios.ui.screenshot", "arguments": {}, "saveAs": "screenshot" },
    { "tool": "ios.action.scroll", "arguments": { "direction": "down", "distance": 0.6 } },
    { "tool": "ios.action.scroll", "arguments": { "direction": "down", "distance": 0.6 } },
    { "tool": "ios.action.scroll", "arguments": { "direction": "down", "distance": 0.6 } },
    { "tool": "ios.action.scroll", "arguments": { "direction": "down", "distance": 0.6 } },
    {
      "tool": "ios.ui.extract_rows",
      "saveAs": "categoryRows",
      "arguments": {
        "row": {
          "type": "XCUIElementTypeCell",
          "namePrefix": "AppStore.shelfItem.annotation",
          "labelContains": "Category"
        },
        "primary": {
          "type": "XCUIElementTypeCell",
          "attr": "label",
          "pick": "first"
        },
        "split": {
          "delimiter": ",",
          "fields": ["label", "category"],
          "skipMetricLike": true
        },
        "limit": 1
      }
    },
    {
      "tool": "util.list.first",
      "saveAs": "categoryFirst",
      "arguments": { "list": "{{steps.categoryRows.rows}}" }
    },
    { "tool": "ios.ui.source", "arguments": {}, "saveAs": "uiSource" },
    {
      "tool": "util.list.first",
      "saveAs": "topRow",
      "arguments": { "list": "{{steps.topLockup.rows}}" }
    }
  ],
  "output": {
    "query": "{{query}}",
    "result_index": "{{result_index}}",
    "title": "{{steps.topRow.value.title}}",
    "tagline": "{{steps.topRow.value.tagline}}",
    "subtitle": "{{steps.topRow.value.subtitle}}",
    "developer": "{{steps.topRow.value.developer}}",
    "offer": "{{steps.topRow.value.offer}}",
    "offerSubtitle": "{{steps.topRow.value.offerSubtitle}}",
    "badges": "{{steps.badges.texts}}",
    "category": "{{steps.categoryFirst.value.category}}",
    "screenshotItems": "{{steps.screenshots.rows}}",
    "screenshotCount": "{{steps.screenshots.rowCount}}",
    "screenshot": "{{steps.screenshot}}",
    "uiSource": "{{steps.uiSource}}"
  }
}
