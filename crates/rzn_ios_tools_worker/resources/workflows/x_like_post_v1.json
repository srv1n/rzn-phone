{
  "schema_version": "rzn.mobile.workflow.v1",
  "name": "x.like_post",
  "version": "1.0.0",
  "description": "Open a visible X post and optionally like it with commit gating.",
  "inputs": {
    "execute_like": { "type": "boolean", "default": false },
    "post_position": { "type": "integer", "default": 1, "min": 1, "max": 4 },
    "maxNodes": { "type": "integer", "default": 240, "min": 80, "max": 420 }
  },
  "notes": [
    "Dry-run by default.",
    "The workflow opens the post detail first, then taps `StatusFavoriteButton` only when commit=true and execute_like=true."
  ],
  "steps": [
    { "tool": "ios.appium.ensure", "arguments": {} },
    {
      "tool": "ios.session.create",
      "arguments": {
        "udid": "{{udid}}",
        "kind": "native_app",
        "bundleId": "com.atebits.Tweetie2",
        "replaceExisting": true,
        "noReset": true,
        "showXcodeLog": "{{showXcodeLog}}",
        "allowProvisioningUpdates": "{{allowProvisioningUpdates}}",
        "allowProvisioningDeviceRegistration": "{{allowProvisioningDeviceRegistration}}",
        "sessionCreateTimeoutMs": "{{sessionCreateTimeoutMs}}",
        "wdaLocalPort": "{{wdaLocalPort}}",
        "wdaLaunchTimeoutMs": "{{wdaLaunchTimeoutMs}}",
        "wdaConnectionTimeoutMs": "{{wdaConnectionTimeoutMs}}",
        "signing": {
          "xcodeOrgId": "{{xcodeOrgId}}",
          "xcodeSigningId": "{{xcodeSigningId}}",
          "updatedWDABundleId": "{{updatedWDABundleId}}"
        }
      }
    },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "slideshowClose",
      "arguments": {
        "query": { "type": "XCUIElementTypeButton", "name": "CloseButton", "max": 1 },
        "limit": 1,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "util.list.length",
      "saveAs": "slideshowCloseCount",
      "arguments": { "list": "{{steps.slideshowClose.texts}}" }
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "steps.slideshowCloseCount.count", "truthy": true },
      "arguments": { "target": { "using": "accessibility id", "value": "CloseButton" } }
    },
    {
      "tool": "util.sleep",
      "when": { "var": "steps.slideshowCloseCount.count", "truthy": true },
      "arguments": { "minMs": 900, "maxMs": 900 }
    },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "timelineBack",
      "arguments": {
        "query": { "type": "XCUIElementTypeButton", "name": "Timeline", "max": 1 },
        "limit": 1,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "util.list.length",
      "saveAs": "timelineBackCount",
      "arguments": { "list": "{{steps.timelineBack.texts}}" }
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "steps.timelineBackCount.count", "truthy": true },
      "arguments": { "target": { "using": "accessibility id", "value": "Timeline" } }
    },
    {
      "tool": "util.sleep",
      "when": { "var": "steps.timelineBackCount.count", "truthy": true },
      "arguments": { "minMs": 1100, "maxMs": 1100 }
    },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "composeCancel",
      "arguments": {
        "query": { "type": "XCUIElementTypeButton", "name": "Cancel", "max": 1 },
        "limit": 1,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "util.list.length",
      "saveAs": "composeCancelCount",
      "arguments": { "list": "{{steps.composeCancel.texts}}" }
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "steps.composeCancelCount.count", "truthy": true },
      "arguments": { "target": { "using": "accessibility id", "value": "Cancel" } }
    },
    {
      "tool": "util.sleep",
      "when": { "var": "steps.composeCancelCount.count", "truthy": true },
      "arguments": { "minMs": 800, "maxMs": 800 }
    },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "saveDraftPrompt",
      "arguments": {
        "query": { "type": "XCUIElementTypeButton", "labelContains": "Save", "max": 1 },
        "limit": 1,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "util.list.length",
      "saveAs": "saveDraftPromptCount",
      "arguments": { "list": "{{steps.saveDraftPrompt.texts}}" }
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "steps.saveDraftPromptCount.count", "truthy": true },
      "arguments": {
        "target": {
          "using": "-ios predicate string",
          "value": "type == 'XCUIElementTypeButton' AND (label CONTAINS[c] 'Save' OR name CONTAINS[c] 'Save')"
        }
      }
    },
    {
      "tool": "util.sleep",
      "when": { "var": "steps.saveDraftPromptCount.count", "truthy": true },
      "arguments": { "minMs": 1000, "maxMs": 1000 }
    },
    {
      "tool": "ios.ui.extract_text",
      "saveAs": "homeTabVisible",
      "arguments": {
        "query": { "type": "XCUIElementTypeOther", "name": "Timelines_tab", "max": 1 },
        "limit": 1,
        "unique": true,
        "order": "y"
      }
    },
    {
      "tool": "util.list.length",
      "saveAs": "homeTabVisibleCount",
      "arguments": { "list": "{{steps.homeTabVisible.texts}}" }
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "steps.homeTabVisibleCount.count", "truthy": true },
      "arguments": { "point": { "x": 38, "y": 754 } }
    },
    { "tool": "util.sleep", "arguments": { "minMs": 2200, "maxMs": 2200 } },
    {
      "tool": "ios.ui.extract_rows",
      "saveAs": "feedRows",
      "arguments": {
        "row": {
          "type": "XCUIElementTypeCell",
          "ancestorName": "THFHomeTimelineItems Table"
        },
        "primary": {
          "type": "XCUIElementTypeCell",
          "attr": "label",
          "pick": "first"
        },
        "fields": [
          {
            "name": "postId",
            "query": {
              "type": "XCUIElementTypeCell",
              "ancestorName": "THFHomeTimelineItems Table",
              "max": 1
            },
            "attr": "name",
            "pick": "first"
          }
        ],
        "limit": 4,
        "order": "y"
      }
    },
    {
      "tool": "util.list.nth",
      "saveAs": "selectedPost",
      "arguments": { "list": "{{steps.feedRows.rows}}", "index": "{{post_position}}" }
    },
    {
      "tool": "ios.action.tap",
      "arguments": {
        "point": {
          "x": "{{steps.selectedPost.value.tapX}}",
          "y": "{{steps.selectedPost.value.tapY}}"
        }
      }
    },
    { "tool": "util.sleep", "arguments": { "minMs": 2600, "maxMs": 2600 } },
    { "tool": "ios.ui.screenshot", "arguments": {}, "saveAs": "beforeLikeScreenshot" },
    { "tool": "ios.ui.source", "arguments": {}, "saveAs": "beforeLikeUiSource" },
    {
      "tool": "ios.ui.observe_compact",
      "arguments": { "nodeFilter": "all", "maxNodes": "{{maxNodes}}" },
      "saveAs": "beforeLikeCompactSnapshot"
    },
    {
      "tool": "ios.action.tap",
      "when": { "var": "execute_like", "truthy": true },
      "requiresCommit": true,
      "arguments": { "target": { "using": "accessibility id", "value": "StatusFavoriteButton" } }
    },
    {
      "tool": "ios.ui.screenshot",
      "when": { "var": "execute_like", "truthy": true },
      "arguments": {},
      "saveAs": "afterLikeScreenshot"
    }
  ],
  "output": {
    "requestedLike": "{{execute_like}}",
    "selectedPost": "{{steps.selectedPost.value}}",
    "beforeLikeScreenshot": "{{steps.beforeLikeScreenshot}}",
    "beforeLikeUiSource": "{{steps.beforeLikeUiSource}}",
    "beforeLikeCompactSnapshot": "{{steps.beforeLikeCompactSnapshot}}",
    "afterLikeScreenshot": "{{steps.afterLikeScreenshot}}"
  }
}
