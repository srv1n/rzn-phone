{
  "schema_version": "rzn.social.card.v1",
  "catalog": "x",
  "version": "1.0.0",
  "cards": [
    {
      "id": "x.daily_scroll",
      "title": "Browse Home feed",
      "description": "Scroll the native X Home timeline and extract visible feed rows with safe tap coordinates.",
      "app": "x",
      "mode": "browse",
      "workflow": "x.daily_scroll_digest",
      "mutating": false,
      "commitRequired": false,
      "defaults": {
        "max_posts": 30,
        "max_scrolls": 8,
        "min_dwell_ms": 700,
        "max_dwell_ms": 1800
      },
      "artifacts": ["result.json", "screenshot.png", "ui_source.xml"]
    },
    {
      "id": "x.open_post",
      "title": "Open feed post",
      "description": "Open a visible X feed post by position and collect thread rows from the detail view.",
      "app": "x",
      "mode": "read",
      "workflow": "x.open_post",
      "mutating": false,
      "commitRequired": false,
      "defaults": {
        "post_position": 1,
        "max_thread_rows": 40,
        "max_thread_scrolls": 8
      },
      "artifacts": ["result.json", "screenshot.png", "ui_source.xml"]
    },
    {
      "id": "x.like_post",
      "title": "Like post",
      "description": "Optionally like a visible X feed post with dual execute and commit gates.",
      "app": "x",
      "mode": "engage",
      "workflow": "x.like_post",
      "mutating": true,
      "commitRequired": true,
      "executeArg": "execute_like",
      "defaults": {
        "post_position": 1,
        "execute_like": false
      },
      "artifacts": ["result.json", "screenshot.png", "ui_source.xml"]
    },
    {
      "id": "x.reply_post",
      "title": "Reply to post",
      "description": "Draft and optionally submit a reply on a visible X feed post.",
      "app": "x",
      "mode": "engage",
      "workflow": "x.reply_post",
      "mutating": true,
      "commitRequired": true,
      "executeArg": "execute_reply",
      "textArg": "reply_text",
      "requiredArgs": ["reply_text"],
      "defaults": {
        "post_position": 1,
        "execute_reply": false
      },
      "artifacts": ["result.json", "screenshot.png", "ui_source.xml"]
    },
    {
      "id": "x.create_post",
      "title": "Create post",
      "description": "Draft and optionally publish a new X post from the native composer.",
      "app": "x",
      "mode": "publish",
      "workflow": "x.create_post",
      "mutating": true,
      "commitRequired": true,
      "executeArg": "execute_post",
      "textArg": "post_text",
      "requiredArgs": ["post_text"],
      "defaults": {
        "execute_post": false
      },
      "artifacts": ["result.json", "screenshot.png", "ui_source.xml"]
    },
    {
      "id": "x.open_inbox",
      "title": "Open inbox",
      "description": "Open the native X DM/X Chat surface for read-only inspection and report passcode gating when present.",
      "app": "x",
      "mode": "read",
      "workflow": "x.open_inbox",
      "mutating": false,
      "commitRequired": false,
      "defaults": {
        "max_visible_threads": 20
      },
      "artifacts": ["result.json", "screenshot.png", "ui_source.xml"]
    },
    {
      "id": "x.open_dm_thread",
      "title": "Open DM thread",
      "description": "Open a visible X DM thread for read-only inspection when X Chat is accessible.",
      "app": "x",
      "mode": "read",
      "workflow": "x.open_dm_thread",
      "mutating": false,
      "commitRequired": false,
      "defaults": {
        "thread_position": 1,
        "max_visible_threads": 20,
        "max_thread_rows": 60,
        "max_thread_scrolls": 8
      },
      "artifacts": ["result.json", "screenshot.png", "ui_source.xml"]
    },
    {
      "id": "x.send_dm",
      "title": "Send DM",
      "description": "Draft and optionally send a direct message inside a visible X DM thread when X Chat is accessible.",
      "app": "x",
      "mode": "engage",
      "workflow": "x.send_dm",
      "mutating": true,
      "commitRequired": true,
      "executeArg": "execute_send",
      "textArg": "message_text",
      "requiredArgs": ["message_text"],
      "defaults": {
        "thread_position": 1,
        "max_visible_threads": 20,
        "execute_send": false
      },
      "artifacts": ["result.json", "screenshot.png", "ui_source.xml"]
    },
    {
      "id": "x.reply_dm",
      "title": "Reply in DM",
      "description": "Draft and optionally send a reply inside a visible X DM thread when X Chat is accessible.",
      "app": "x",
      "mode": "engage",
      "workflow": "x.reply_dm_thread",
      "mutating": true,
      "commitRequired": true,
      "executeArg": "execute_reply",
      "textArg": "message_text",
      "requiredArgs": ["message_text"],
      "defaults": {
        "thread_position": 1,
        "max_visible_threads": 20,
        "execute_reply": false
      },
      "artifacts": ["result.json", "screenshot.png", "ui_source.xml"]
    }
  ]
}
