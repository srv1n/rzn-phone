  "mcp_protocol_version": "2025-06-18",
  "requires_entitlement": false,
  "required_product_ids": [],
  "platforms": ["macos_universal"],
  "workers": [
    {
      "id": "ios",
      "kind": "mcp_stdio",
      "auto_start": false,
      "tools_namespace": "plugin:rzn-phone",
      "entrypoints": {
        "macos_universal": "bin/macos/universal/rzn-phone-worker"
      },
      "args": [],
      "env": {}
    }
  ],
